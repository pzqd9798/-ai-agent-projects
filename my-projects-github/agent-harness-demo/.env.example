# =============================================================================
#  Agent Harness Demo — Configuration
# =============================================================================

# Required: Your API key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Required: Model to use
MODEL_ID=claude-sonnet-4-6

# Optional: Base URL for Anthropic-compatible providers
# Leave empty for official Anthropic API
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# =============================================================================
#  Compatible Providers (use with ANTHROPIC_BASE_URL)
# =============================================================================

# DeepSeek (cheapest, good for learning)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-chat

# MiniMax
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# MODEL_ID=glm-5

# Kimi (Moonshot)
# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# MODEL_ID=kimi-k2.5
