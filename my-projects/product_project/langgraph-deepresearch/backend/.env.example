# =============================================================================
# Deep Research Platform — Environment Configuration
# =============================================================================

# --- LLM Provider ---
LLM_PROVIDER=deepseek          # Options: deepseek, openai, ollama, lmstudio, custom
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL_ID=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=120

# Local model options
# LLM_PROVIDER=ollama
# LOCAL_LLM=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# LLM_PROVIDER=lmstudio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# --- Search ---
SEARCH_API=duckduckgo          # Options: duckduckgo, tavily, searxng, perplexity, advanced
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
SEARXNG_BASE_URL=http://localhost:8080
SEARCH_CACHE_TTL=300           # Search result cache TTL in seconds
FETCH_FULL_PAGE=true

# --- Research ---
MAX_WEB_RESEARCH_LOOPS=3
ENABLE_NOTES=true
NOTES_WORKSPACE=./notes

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/deepresearch.db

# --- Authentication ---
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRE_HOURS=168           # 1 week

# --- Server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174
LOG_LEVEL=INFO

# --- Observability ---
# Set LOG_LEVEL=DEBUG for verbose output
# Metrics available at /metrics
